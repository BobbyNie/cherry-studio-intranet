CHERRY_INTRANET_MODE=true

# Optional seed allowlist for first launch (comma- or newline-separated hostnames).
# Runtime policy is managed in Settings -> General -> Intranet network allowlist.
# Examples:
# CHERRY_NETWORK_ALLOWLIST=llm-gateway.intranet.local,*.corp.example.com,127.0.0.1
CHERRY_NETWORK_ALLOWLIST=

# Optional hard-disable switches. Leave unset unless your deployment policy
# intentionally wants these product surfaces disabled instead of governed by
# the central network allowlist.
# CHERRY_DISABLE_AUTO_UPDATE=true
# CHERRY_DISABLE_TELEMETRY=true
# CHERRY_DISABLE_MARKETPLACE=true
# CHERRY_DISABLE_EXTERNAL_LINKS=true
