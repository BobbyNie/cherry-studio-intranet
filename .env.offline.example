# Fully Offline Edition example environment
# Copy to .env.offline before building or running offline packages.

CHERRY_OFFLINE_MODE=true
CHERRY_INTRANET_MODE=true
CHERRY_DISABLE_PUBLIC_NETWORK=true
CHERRY_DISABLE_AUTO_UPDATE=true
CHERRY_DISABLE_TELEMETRY=true
CHERRY_DISABLE_MARKETPLACE=true
CHERRY_DISABLE_EXTERNAL_LINKS=true

# Do not set remote API keys or BASE_URL in offline builds.
# Local model service is disabled by default; configure it in Settings after install.
CHERRY_LOCAL_MODEL_ALLOWED_PORTS=

# Local logging only
CSLOGGER_MAIN_LEVEL=info
CSLOGGER_RENDERER_LEVEL=info
